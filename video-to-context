#!/usr/bin/env python3
"""
video-to-context: Reusable pipeline for extracting full context from video files.

Pipeline steps:
  1. Extract audio via ffmpeg
  2. Transcribe with WhisperX (word-level timestamps)
  3. Analyze transcript for topic boundaries → pick smart screenshot timestamps
  4. Extract frames at those timestamps via ffmpeg
  5. Hybrid OCR: PaddleOCR extracts text (zero hallucination) + Qwen3-VL describes visual layout
  6. Produce a rich VTT file with transcription + visual context notes

Usage:
  video-to-context <input_video> [options]

Examples:
  video-to-context recording.mkv
  video-to-context recording.mkv --whisper-model large-v3 --language en --max-screenshots 20
  video-to-context recording.mkv --vlm-model Qwen/Qwen3-VL-8B-Instruct
  video-to-context recording.mkv --no-vlm          # PaddleOCR text only, no VLM
  video-to-context recording.mkv --no-paddleocr    # VLM only (higher hallucination risk)

Output:
  <input_stem>/
    audio.wav           - extracted audio
    transcript.json     - raw WhisperX output with word-level timestamps
    frames/             - extracted screenshots (frame_001.jpg, etc.)
    ocr_results.json    - OCR descriptions per frame
    output.vtt          - final VTT with transcription + [VISUAL] context notes
"""

import argparse
import json
import os
import re
import subprocess
import sys
import tempfile
from pathlib import Path
from dataclasses import dataclass, field, asdict
from typing import Optional


# ---------------------------------------------------------------------------
# Step 1: Extract audio
# ---------------------------------------------------------------------------
def extract_audio(video_path: Path, output_dir: Path, sample_rate: int = 16000) -> Path:
    """Extract audio from video as 16kHz mono WAV (required by WhisperX)."""
    audio_path = output_dir / "audio.wav"
    if audio_path.exists():
        print(f"[audio] Already exists: {audio_path}")
        return audio_path

    print(f"[audio] Extracting audio from {video_path} → {audio_path}")
    cmd = [
        "ffmpeg", "-y", "-i", str(video_path),
        "-vn",                    # no video
        "-ar", str(sample_rate),  # 16kHz
        "-ac", "1",               # mono
        "-f", "wav",
        str(audio_path),
    ]
    result = subprocess.run(cmd, capture_output=True, text=True)
    if result.returncode != 0:
        print(f"[audio] ffmpeg error: {result.stderr}", file=sys.stderr)
        sys.exit(1)
    print(f"[audio] Done: {audio_path}")
    return audio_path


# ---------------------------------------------------------------------------
# Step 2: WhisperX transcription
# ---------------------------------------------------------------------------
def transcribe_audio(
    audio_path: Path,
    output_dir: Path,
    whisper_model: str = "large-v3",
    language: Optional[str] = None,
    device: str = "cuda",
    compute_type: str = "float16",
) -> dict:
    """Run WhisperX transcription with word-level timestamps."""
    transcript_path = output_dir / "transcript.json"
    if transcript_path.exists():
        print(f"[whisperx] Loading existing transcript: {transcript_path}")
        return json.loads(transcript_path.read_text())

    print(f"[whisperx] Loading model: {whisper_model} (device={device}, compute_type={compute_type})")
    import whisperx

    audio = whisperx.load_audio(str(audio_path))

    # --- Transcribe ---
    model = whisperx.load_model(
        whisper_model,
        device=device,
        compute_type=compute_type,
        language=language,
    )
    result = model.transcribe(audio, batch_size=16, language=language)
    print(f"[whisperx] Transcribed {len(result['segments'])} segments")

    # --- Align for word-level timestamps ---
    if language and language != "auto":
        print(f"[whisperx] Aligning with language={language}...")
        try:
            model_a, metadata = whisperx.load_align_model(language_code=language, device=device)
            result = whisperx.align(
                result["segments"],
                model_a,
                metadata,
                audio,
                device=device,
                return_char_alignments=False,
            )
            print(f"[whisperx] Aligned: {len(result['segments'])} segments with word-level timestamps")
        except Exception as e:
            print(f"[whisperx] Alignment failed (continuing without word timestamps): {e}")
    else:
        print("[whisperx] Skipping alignment (no language specified or 'auto')")

    # Save
    # Convert any numpy types for JSON serialization
    def sanitize(obj):
        import numpy as np
        if isinstance(obj, (np.integer,)):
            return int(obj)
        if isinstance(obj, (np.floating,)):
            return float(obj)
        if isinstance(obj, np.ndarray):
            return obj.tolist()
        if isinstance(obj, dict):
            return {k: sanitize(v) for k, v in obj.items()}
        if isinstance(obj, list):
            return [sanitize(v) for v in obj]
        return obj

    result = sanitize(result)
    transcript_path.write_text(json.dumps(result, indent=2, ensure_ascii=False))
    print(f"[whisperx] Saved: {transcript_path}")
    return result


# ---------------------------------------------------------------------------
# Step 3: Smart timestamp selection for screenshots
# ---------------------------------------------------------------------------
@dataclass
class ScreenshotPlan:
    timestamp: float
    reason: str


def pick_screenshot_timestamps(
    transcript: dict,
    max_screenshots: int = 15,
    min_interval_seconds: float = 10.0,
    topic_gap_factor: float = 2.0,
) -> list[ScreenshotPlan]:
    """
    Analyze transcript to pick smart screenshot timestamps.

    Strategy:
    - Topic boundaries: where there's a significant pause (gap > mean * factor)
    - Even coverage: divide video into chunks and pick one per chunk
    - Start of new dense speech after silence
    """
    segments = transcript.get("segments", [])
    if not segments:
        return []

    plans: list[ScreenshotPlan] = []
    total_duration = segments[-1]["end"]

    # --- Strategy 1: Topic boundaries (large gaps between segments) ---
    gaps = []
    for i in range(1, len(segments)):
        gap = segments[i]["start"] - segments[i - 1]["end"]
        gaps.append((gap, i))

    if gaps:
        gap_durations = [g[0] for g in gaps]
        mean_gap = sum(gap_durations) / len(gap_durations)
        threshold = mean_gap * topic_gap_factor

        for gap_dur, seg_idx in gaps:
            if gap_dur >= threshold:
                ts = segments[seg_idx]["start"]
                plans.append(ScreenshotPlan(
                    timestamp=ts,
                    reason=f"Topic boundary (gap={gap_dur:.1f}s)"
                ))

    # --- Strategy 2: Even coverage across the video ---
    # Ensure we get screenshots even if there are no big topic breaks
    interval = total_duration / max_screenshots
    coverage_timestamps = set()
    for i in range(max_screenshots):
        target_ts = i * interval + interval / 2  # middle of each chunk

        # Find the nearest segment start that has speech near this time
        best_seg = None
        best_dist = float("inf")
        for seg in segments:
            if seg["start"] <= target_ts <= seg["end"] + 5:
                dist = abs(seg["start"] - target_ts)
                if dist < best_dist:
                    best_dist = dist
                    best_seg = seg

        if best_seg:
            coverage_timestamps.add(best_seg["start"])

    for ts in coverage_timestamps:
        # Don't add if too close to an existing plan
        if not any(abs(p.timestamp - ts) < min_interval_seconds for p in plans):
            plans.append(ScreenshotPlan(
                timestamp=ts,
                reason="Even coverage"
            ))

    # --- Strategy 3: Always include first and last meaningful segment ---
    if segments:
        first_ts = segments[0]["start"]
        if not any(abs(p.timestamp - first_ts) < min_interval_seconds for p in plans):
            plans.append(ScreenshotPlan(timestamp=first_ts, reason="Video start"))

    # Sort by timestamp
    plans.sort(key=lambda p: p.timestamp)

    # --- Deduplicate with min interval ---
    deduped = []
    for plan in plans:
        if not deduped or plan.timestamp - deduped[-1].timestamp >= min_interval_seconds:
            deduped.append(plan)

    # Cap to max
    if len(deduped) > max_screenshots:
        # Keep topic boundaries first, then spread coverage evenly
        topic_plans = [p for p in deduped if "boundary" in p.reason]
        coverage_plans = [p for p in deduped if "boundary" not in p.reason]

        # Take all topic boundaries, fill rest with evenly-spaced coverage
        remaining = max_screenshots - len(topic_plans)
        if remaining > 0 and coverage_plans:
            step = max(1, len(coverage_plans) // remaining)
            selected_coverage = coverage_plans[::step][:remaining]
        else:
            selected_coverage = []

        deduped = sorted(topic_plans + selected_coverage, key=lambda p: p.timestamp)

    print(f"[screenshots] Planned {len(deduped)} screenshots across {total_duration:.0f}s of video")
    for p in deduped:
        mm, ss = divmod(int(p.timestamp), 60)
        print(f"  {mm:02d}:{ss:02d} - {p.reason}")

    return deduped


# ---------------------------------------------------------------------------
# Step 4: Extract frames via ffmpeg
# ---------------------------------------------------------------------------
def extract_frames(
    video_path: Path,
    plans: list[ScreenshotPlan],
    output_dir: Path,
    width: int = 1280,
) -> list[Path]:
    """Extract screenshot frames at planned timestamps."""
    frames_dir = output_dir / "frames"
    frames_dir.mkdir(exist_ok=True)

    frame_paths = []
    for i, plan in enumerate(plans):
        frame_path = frames_dir / f"frame_{i + 1:03d}.jpg"
        frame_paths.append(frame_path)

        if frame_path.exists():
            print(f"[frames] Already exists: {frame_path}")
            continue

        timestamp = plan.timestamp
        print(f"[frames] Extracting frame at {timestamp:.2f}s → {frame_path}")
        cmd = [
            "ffmpeg", "-y",
            "-ss", f"{timestamp:.3f}",
            "-i", str(video_path),
            "-vframes", "1",
            "-q:v", "2",  # high quality JPEG
            str(frame_path),
        ]
        result = subprocess.run(cmd, capture_output=True, text=True)
        if result.returncode != 0:
            print(f"[frames] ffmpeg error at {timestamp:.2f}s: {result.stderr}", file=sys.stderr)

    print(f"[frames] Extracted {len(frame_paths)} frames")
    return frame_paths


# ---------------------------------------------------------------------------
# Step 5a: PaddleOCR text extraction (zero hallucination)
# ---------------------------------------------------------------------------
def paddleocr_extract(frame_paths: list[Path], output_dir: Path, lang: str = "en") -> dict[str, list[str]]:
    """Run EasyOCR on each frame for deterministic text extraction.
    Returns {frame_key: [list of text strings found]}.
    """
    ocr_text_path = output_dir / "paddleocr_results.json"
    if ocr_text_path.exists():
        print(f"[easyocr] Loading existing results: {ocr_text_path}")
        return json.loads(ocr_text_path.read_text())

    print("[easyocr] Initializing EasyOCR...")
    import easyocr

    # Map language codes
    lang_map = {"en": ["en"], "ch": ["ch_sim", "en"], "ja": ["ja", "en"], "ko": ["ko", "en"]}
    ocr_langs = lang_map.get(lang, ["en"])

    reader = easyocr.Reader(ocr_langs, gpu=True)

    results = {}
    for i, frame_path in enumerate(frame_paths):
        key = f"frame_{i + 1:03d}"
        print(f"[easyocr] Processing {key}: {frame_path.name}")

        try:
            detections = reader.readtext(str(frame_path))
            texts = []
            for bbox, text, confidence in detections:
                if confidence >= 0.3:  # filter low-confidence
                    texts.append(f"{text} (conf={confidence:.2f})")
            results[key] = texts
            preview = "; ".join(t.split(" (conf=")[0] for t in texts[:8])
            if len(texts) > 8:
                preview += f" ... (+{len(texts) - 8} more)"
            print(f"  → {len(texts)} text regions: {preview}")
        except Exception as e:
            print(f"  ⚠ EasyOCR failed for {key}: {e}", file=sys.stderr)
            results[key] = []

    ocr_text_path.write_text(json.dumps(results, indent=2, ensure_ascii=False))
    print(f"[easyocr] Saved: {ocr_text_path}")

    # Free EasyOCR GPU memory
    del reader
    import gc
    gc.collect()
    import torch
    if torch.cuda.is_available():
        torch.cuda.empty_cache()

    return results


# ---------------------------------------------------------------------------
# Step 5b: VLM visual description (Qwen3-VL)
# ---------------------------------------------------------------------------
def vlm_describe_frames(
    frame_paths: list[Path],
    plans: list[ScreenshotPlan],
    paddleocr_results: dict[str, list[str]],
    output_dir: Path,
    vlm_model_name: str = "Qwen/Qwen3-VL-8B-Instruct",
    device: str = "cuda",
) -> dict[str, dict]:
    """Run VLM on each frame for visual layout description.
    PaddleOCR text is injected into the prompt so the VLM doesn't need to
    read text — it focuses on describing UI elements, layout, and context.
    """
    vlm_path = output_dir / "vlm_results.json"

    # Load any existing partial results for resume support
    existing_results = {}
    if vlm_path.exists():
        existing_results = json.loads(vlm_path.read_text())
        print(f"[vlm] Found existing results with {len(existing_results)} frames")

    # Check if all frames are already done
    all_frame_keys = {f"frame_{i + 1:03d}" for i in range(len(frame_paths))}
    if all_frame_keys.issubset(existing_results.keys()):
        print(f"[vlm] All {len(frame_paths)} frames already processed")
        return existing_results

    print(f"[vlm] Loading model: {vlm_model_name}")
    import torch
    import gc

    # Detect model family for correct class
    is_qwen3 = "qwen3" in vlm_model_name.lower()
    is_qwen25 = "qwen2.5" in vlm_model_name.lower() or "qwen2_5" in vlm_model_name.lower()

    if is_qwen3:
        from transformers import Qwen3VLForConditionalGeneration, AutoProcessor, BitsAndBytesConfig
        from qwen_vl_utils import process_vision_info
        model_cls = Qwen3VLForConditionalGeneration
    elif is_qwen25:
        from transformers import Qwen2_5_VLForConditionalGeneration, AutoProcessor, BitsAndBytesConfig
        from qwen_vl_utils import process_vision_info
        model_cls = Qwen2_5_VLForConditionalGeneration
    else:
        from transformers import Qwen2_5_VLForConditionalGeneration, AutoProcessor, BitsAndBytesConfig
        from qwen_vl_utils import process_vision_info
        model_cls = Qwen2_5_VLForConditionalGeneration

    # Use 4-bit quantization for 7B+ models to fit in 16GB VRAM
    is_large_model = any(s in vlm_model_name.lower() for s in ['7b', '8b', '72b'])

    if is_large_model:
        quantization_config = BitsAndBytesConfig(
            load_in_4bit=True,
            bnb_4bit_quant_type="nf4",
            bnb_4bit_compute_dtype=torch.bfloat16,
            bnb_4bit_use_double_quant=True,
        )
        print(f"[vlm] Using 4-bit quantization (NF4) for large model")
        model = model_cls.from_pretrained(
            vlm_model_name,
            quantization_config=quantization_config,
            device_map="auto",
        )
    else:
        dtype = torch.bfloat16 if torch.cuda.is_bf16_supported() else torch.float16
        print(f"[vlm] Using dtype: {dtype}")
        model = model_cls.from_pretrained(
            vlm_model_name,
            torch_dtype=dtype,
            device_map="auto",
        )
    processor = AutoProcessor.from_pretrained(vlm_model_name)

    results = dict(existing_results)

    for i, (frame_path, plan) in enumerate(zip(frame_paths, plans)):
        key = f"frame_{i + 1:03d}"

        # Skip already-processed frames
        if key in results:
            print(f"[vlm] Skipping already processed: {key}")
            continue

        # Build prompt with PaddleOCR text already extracted
        ocr_texts = paddleocr_results.get(key, [])
        ocr_text_block = ""
        if ocr_texts:
            ocr_text_block = "\nText already extracted by OCR (do NOT re-read these, they are confirmed):\n" + "\n".join(f"  - {t}" for t in ocr_texts) + "\n\n"

        prompt_text = (
            "You are describing a screenshot for someone who cannot see it. "
            "Focus ONLY on the visual layout and what kind of interface this is. "
            "Do NOT try to read text — an OCR engine has already extracted the visible text below. "
            f"{ocr_text_block}"
            "Describe:\n"
            "1. What type of screen is this? (game UI, menu, settings, combat, map, etc.)\n"
            "2. What are the major visual sections/panels and where are they? (left sidebar, top bar, center area, etc.)\n"
            "3. What visual elements are present? (health bars, maps, hex grids, ship icons, buttons, sliders, etc.)\n"
            "4. What is the apparent state of the game/app? (combat active, menu open, turn number if visible, etc.)\n"
            "Be concise and factual. Do NOT guess at text content."
        )

        print(f"[vlm] Processing frame {i + 1}/{len(frame_paths)}: {frame_path.name} ({plan.reason})")

        try:
            messages = [
                {
                    "role": "user",
                    "content": [
                        {"type": "image", "image": f"file://{frame_path.resolve()}"},
                        {"type": "text", "text": prompt_text},
                    ],
                }
            ]

            text = processor.apply_chat_template(messages, tokenize=False, add_generation_prompt=True)
            image_inputs, video_inputs = process_vision_info(messages)
            inputs = processor(
                text=[text],
                images=image_inputs,
                videos=video_inputs,
                padding=True,
                return_tensors="pt",
            ).to(model.device)

            with torch.no_grad():
                generated_ids = model.generate(**inputs, max_new_tokens=512)

            generated_ids_trimmed = [
                out_ids[len(in_ids):] for in_ids, out_ids in zip(inputs.input_ids, generated_ids)
            ]
            description = processor.batch_decode(
                generated_ids_trimmed, skip_special_tokens=True, clean_up_tokenization_spaces=False
            )[0]

            results[key] = {
                "timestamp": plan.timestamp,
                "reason": plan.reason,
                "frame_file": frame_path.name,
                "visual_description": description.strip(),
                "ocr_text": ocr_texts,
            }
            preview = description[:120].replace("\n", " ")
            print(f"  → {preview}...")

        except Exception as e:
            print(f"  ⚠ VLM failed for {key}: {e}", file=sys.stderr)
            results[key] = {
                "timestamp": plan.timestamp,
                "reason": plan.reason,
                "frame_file": frame_path.name,
                "visual_description": f"[VLM FAILED: {e}]",
                "ocr_text": ocr_texts,
            }

        # Clear GPU cache between frames
        try:
            del inputs
        except NameError:
            pass
        try:
            del generated_ids
        except NameError:
            pass
        try:
            del generated_ids_trimmed
        except NameError:
            pass
        gc.collect()
        torch.cuda.empty_cache()

        # Save incremental progress
        vlm_path.write_text(json.dumps(results, indent=2, ensure_ascii=False))

    # Free GPU memory
    del model
    gc.collect()
    torch.cuda.empty_cache()

    print(f"[vlm] Saved: {vlm_path} ({len(results)} frames)")
    return results


# ---------------------------------------------------------------------------
# Step 5c: Merge PaddleOCR + VLM into unified OCR results
# ---------------------------------------------------------------------------
def merge_ocr_results(
    paddleocr_results: dict[str, list[str]],
    vlm_results: dict[str, dict],
    output_dir: Path,
) -> dict[str, dict]:
    """Merge PaddleOCR text and VLM visual descriptions into a unified result."""
    ocr_path = output_dir / "ocr_results.json"

    results = {}
    for key in vlm_results:
        vlm = vlm_results[key]
        ocr_texts = paddleocr_results.get(key, [])

        # Build combined description for VTT
        combined = []
        if ocr_texts:
            combined.append("EXTRACTED TEXT (OCR):")
            for t in ocr_texts:
                combined.append(f"  • {t}")
        vis_desc = vlm.get("visual_description", "")
        if vis_desc and not vis_desc.startswith("[VLM FAILED"):
            combined.append("")
            combined.append("VISUAL LAYOUT:")
            combined.append(vis_desc)

        results[key] = {
            "timestamp": vlm.get("timestamp", 0),
            "reason": vlm.get("reason", ""),
            "frame_file": vlm.get("frame_file", ""),
            "ocr_text": ocr_texts,
            "visual_description": vis_desc,
            "description": "\n".join(combined),
        }

    ocr_path.write_text(json.dumps(results, indent=2, ensure_ascii=False))
    print(f"[merge] Saved unified results: {ocr_path} ({len(results)} frames)")
    return results


# ---------------------------------------------------------------------------
# Step 6: Produce rich VTT output
# ---------------------------------------------------------------------------
def format_vtt_timestamp(seconds: float) -> str:
    """Format seconds as HH:MM:SS.mmm for VTT."""
    h = int(seconds // 3600)
    m = int((seconds % 3600) // 60)
    s = seconds % 60
    whole_s = int(s)
    ms = int((s - whole_s) * 1000)
    return f"{h:02d}:{m:02d}:{whole_s:02d}.{ms:03d}"


def produce_vtt(
    transcript: dict,
    ocr_results: dict,
    plans: list[ScreenshotPlan],
    output_dir: Path,
    video_name: str = "video",
) -> Path:
    """Generate a rich VTT file with transcription + visual context."""
    vtt_path = output_dir / "output.vtt"

    # Build a sorted list of visual events (from OCR results)
    visual_events = []
    for key, data in ocr_results.items():
        visual_events.append({
            "timestamp": data["timestamp"],
            "frame_key": key,
            "description": data["description"],
        })
    visual_events.sort(key=lambda e: e["timestamp"])

    # Build VTT cues from transcript segments
    lines = ["WEBVTT", ""]
    lines.append(f"NOTE")
    lines.append(f"Video: {video_name}")
    lines.append(f"Generated by video-to-context pipeline")
    lines.append(f"Segments: {len(transcript.get('segments', []))}, Visual contexts: {len(visual_events)}")
    lines.append("")

    segments = transcript.get("segments", [])

    # Interleave visual context notes with transcript cues
    # Strategy: insert a [VISUAL] cue just before the nearest segment
    # to the screenshot timestamp

    # Create a merged timeline
    events = []
    for seg in segments:
        events.append({
            "type": "speech",
            "start": seg["start"],
            "end": seg["end"],
            "text": seg["text"].strip(),
        })

    for ve in visual_events:
        # Truncate description for VTT readability but keep substantial content
        desc = ve["description"]
        events.append({
            "type": "visual",
            "start": ve["timestamp"],
            "end": ve["timestamp"] + 0.1,  # minimal duration
            "text": desc,
            "frame_key": ve["frame_key"],
        })

    # Sort by start time, with visual events before speech at same time
    events.sort(key=lambda e: (e["start"], 0 if e["type"] == "visual" else 1))

    cue_idx = 1
    for event in events:
        start_ts = format_vtt_timestamp(event["start"])
        end_ts = format_vtt_timestamp(event["end"])

        if event["type"] == "visual":
            # Ensure visual cue spans at least 1 second for readability
            min_end = event["start"] + 1.0
            # Extend to the start of the next event if possible
            next_starts = [e["start"] for e in events if e["start"] > event["start"]]
            if next_starts:
                nearest_next = min(next_starts)
                end_time = min(min_end, nearest_next)
            else:
                end_time = min_end
            end_ts = format_vtt_timestamp(end_time)

            lines.append(f"{cue_idx}")
            lines.append(f"{start_ts} --> {end_ts}")
            lines.append(f"[VISUAL 📷 {event['frame_key']}]")
            # Split long descriptions into multiple lines
            desc_lines = event["text"].split("\n")
            for dl in desc_lines:
                dl = dl.strip()
                if dl:
                    lines.append(dl)
            lines.append("")
        else:
            lines.append(f"{cue_idx}")
            lines.append(f"{start_ts} --> {end_ts}")
            lines.append(event["text"])
            lines.append("")

        cue_idx += 1

    vtt_content = "\n".join(lines)
    vtt_path.write_text(vtt_content, encoding="utf-8")
    print(f"[vtt] Generated: {vtt_path} ({cue_idx - 1} cues)")
    return vtt_path


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
def main():
    parser = argparse.ArgumentParser(
        description="Extract full context from video: audio transcription + smart screenshots + OCR",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__,
    )
    parser.add_argument("input", type=Path, help="Input video file")
    parser.add_argument("--output-dir", type=Path, default=None,
                        help="Output directory (default: <input_stem>/ next to video)")
    parser.add_argument("--whisper-model", default="large-v3",
                        choices=["tiny", "base", "small", "medium", "large-v2", "large-v3"],
                        help="WhisperX model size (default: large-v3)")
    parser.add_argument("--language", default=None,
                        help="Language code for WhisperX (e.g. 'en'). Auto-detect if not set.")
    parser.add_argument("--ocr-model", default=None,
                        help="HuggingFace VLM model for visual description (default: Qwen/Qwen3-VL-8B-Instruct)")
    parser.add_argument("--vlm-model", default="Qwen/Qwen3-VL-8B-Instruct",
                        help="Alias for --ocr-model")
    parser.add_argument("--no-paddleocr", action="store_true",
                        help="Skip PaddleOCR text extraction (VLM only — higher hallucination risk)")
    parser.add_argument("--no-vlm", action="store_true",
                        help="Skip VLM visual description (PaddleOCR text only)")
    parser.add_argument("--paddleocr-lang", default="en",
                        help="PaddleOCR language (default: en)")
    parser.add_argument("--max-screenshots", type=int, default=15,
                        help="Maximum number of screenshots to extract (default: 15)")
    parser.add_argument("--min-interval", type=float, default=10.0,
                        help="Minimum seconds between screenshots (default: 10)")
    parser.add_argument("--compute-type", default="float16",
                        choices=["float16", "int8", "float32"],
                        help="WhisperX compute type (default: float16)")
    parser.add_argument("--device", default="cuda",
                        help="Device: cuda or cpu (default: cuda)")
    parser.add_argument("--skip-transcribe", action="store_true",
                        help="Skip transcription step (use existing transcript.json)")
    parser.add_argument("--skip-ocr", action="store_true",
                        help="Skip OCR step (use existing ocr_results.json)")
    parser.add_argument("--skip-frames", action="store_true",
                        help="Skip frame extraction (use existing frames/)")

    args = parser.parse_args()

    # Validate input
    if not args.input.exists():
        print(f"Error: Input file not found: {args.input}", file=sys.stderr)
        sys.exit(1)

    # Setup output directory
    if args.output_dir:
        output_dir = args.output_dir
    else:
        output_dir = args.input.parent / args.input.stem
    output_dir.mkdir(parents=True, exist_ok=True)
    print(f"Output directory: {output_dir}")

    # --- Step 1: Extract audio ---
    audio_path = extract_audio(args.input, output_dir)

    # --- Step 2: WhisperX transcription ---
    if args.skip_transcribe and (output_dir / "transcript.json").exists():
        transcript = json.loads((output_dir / "transcript.json").read_text())
        print(f"[whisperx] Using existing transcript ({len(transcript.get('segments', []))} segments)")
    else:
        import torch
        if not torch.cuda.is_available() and args.device == "cuda":
            print("[!] CUDA not available, falling back to CPU")
            args.device = "cpu"
            args.compute_type = "int8"

        transcript = transcribe_audio(
            audio_path,
            output_dir,
            whisper_model=args.whisper_model,
            language=args.language,
            device=args.device,
            compute_type=args.compute_type,
        )

    # --- Step 3: Pick screenshot timestamps ---
    plans = pick_screenshot_timestamps(
        transcript,
        max_screenshots=args.max_screenshots,
        min_interval_seconds=args.min_interval,
    )

    # --- Step 4: Extract frames ---
    if args.skip_frames and (output_dir / "frames").exists():
        frame_paths = sorted((output_dir / "frames").glob("frame_*.jpg"))
        print(f"[frames] Using existing {len(frame_paths)} frames")
    else:
        frame_paths = extract_frames(args.input, plans, output_dir)

    # --- Step 5: Hybrid OCR (PaddleOCR text + VLM visual description) ---
    vlm_model = args.ocr_model or args.vlm_model

    if args.skip_ocr and (output_dir / "ocr_results.json").exists():
        ocr_results = json.loads((output_dir / "ocr_results.json").read_text())
        print(f"[ocr] Using existing unified OCR results ({len(ocr_results)} frames)")
    else:
        # Step 5a: PaddleOCR for deterministic text extraction
        if args.no_paddleocr:
            paddleocr_results = {f"frame_{i + 1:03d}": [] for i in range(len(frame_paths))}
            print("[paddleocr] Skipped (--no-paddleocr)")
        else:
            paddleocr_results = paddleocr_extract(frame_paths, output_dir, lang=args.paddleocr_lang)

        # Step 5b: VLM for visual layout description
        if args.no_vlm:
            # Build minimal results from PaddleOCR only
            ocr_results = {}
            for i, plan in enumerate(plans):
                key = f"frame_{i + 1:03d}"
                texts = paddleocr_results.get(key, [])
                ocr_results[key] = {
                    "timestamp": plan.timestamp,
                    "reason": plan.reason,
                    "frame_file": frame_paths[i].name,
                    "ocr_text": texts,
                    "visual_description": "",
                    "description": "EXTRACTED TEXT (OCR):\n" + "\n".join(f"  • {t}" for t in texts),
                }
            print("[vlm] Skipped (--no-vlm)")
        else:
            vlm_results = vlm_describe_frames(
                frame_paths,
                plans,
                paddleocr_results,
                output_dir,
                vlm_model_name=vlm_model,
                device=args.device,
            )
            ocr_results = merge_ocr_results(paddleocr_results, vlm_results, output_dir)

    # --- Step 6: Produce VTT ---
    video_name = args.input.stem
    vtt_path = produce_vtt(transcript, ocr_results, plans, output_dir, video_name)

    print("\n" + "=" * 60)
    print("✅ Pipeline complete!")
    print(f"   Output directory: {output_dir}")
    print(f"   VTT file:         {vtt_path}")
    print(f"   Frames:           {output_dir / 'frames'}/")
    print(f"   Transcript:       {output_dir / 'transcript.json'}")
    print(f"   OCR results:      {output_dir / 'ocr_results.json'}")
    print("=" * 60)


if __name__ == "__main__":
    main()
